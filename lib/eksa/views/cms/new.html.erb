<div class="glass max-w-4xl mx-auto rounded-3xl p-10 text-white animate__animated animate__zoomIn animate__faster relative overflow-hidden">
  <div class="absolute inset-0 bg-indigo-500/10 blur-3xl rounded-full translate-x-1/2 -translate-y-1/2"></div>
  
  <div class="relative z-10 flex items-center justify-between mb-8 pb-6 border-b border-white/10">
    <div class="flex items-center gap-4">
      <div class="w-14 h-14 bg-indigo-500/20 rounded-2xl flex items-center justify-center border border-indigo-500/30 shadow-xl shadow-indigo-500/20">
        <i data-lucide="folder-plus" class="w-7 h-7 text-indigo-300"></i>
      </div>
      <div>
        <h1 class="text-3xl font-extrabold tracking-tight">Tambah <span class="text-indigo-300">Project</span></h1>
        <p class="text-white/50 text-sm mt-1">Buat project portofolio baru</p>
      </div>
    </div>
    <a href="/cms" class="px-4 py-2 bg-white/5 hover:bg-white/10 rounded-xl transition border border-white/10 text-sm font-medium flex items-center gap-2">
      <i data-lucide="arrow-left" class="w-4 h-4"></i> Kembali
    </a>
  </div>

  <form action="/cms/create" method="post" enctype="multipart/form-data" class="relative z-10 space-y-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="space-y-2">
        <label class="block text-xs font-bold text-indigo-300 uppercase tracking-widest">Judul Project *</label>
        <input type="text" name="title" required
               class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 transition">
      </div>
      
      <div class="space-y-2">
        <label class="block text-xs font-bold text-indigo-300 uppercase tracking-widest">GitHub URL *</label>
        <input type="url" name="github_url" required
               class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 transition"
               placeholder="https://github.com/username/repo">
      </div>

      <div class="space-y-2">
        <label class="block text-xs font-bold text-indigo-300 uppercase tracking-widest">Demo URL (Opsional)</label>
        <input type="url" name="demo_url"
               class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 transition"
               placeholder="https://example.com">
      </div>

      <div class="space-y-2">
        <label class="block text-xs font-bold text-indigo-300 uppercase tracking-widest">Image Thumbnail (Upload) *</label>
        <input type="file" name="image" accept="image/*"
               class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-2.5 text-white focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 transition file:mr-4 file:py-1 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-indigo-500/20 file:text-indigo-300 hover:file:bg-indigo-500/30">
        <p class="text-[10px] text-white/50 mt-1">Akan diupload otomatis ke Cloudinary</p>
      </div>
    </div>

    <div class="space-y-2 pt-4">
      <label class="block text-xs font-bold text-indigo-300 uppercase tracking-widest">Deskripsi Project *</label>
      <div class="relative group">
        <textarea name="description" required rows="6"
                  class="w-full bg-black/40 border border-white/10 rounded-xl px-5 py-4 text-white focus:outline-none focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 text-sm leading-relaxed transition"></textarea>
        <i data-lucide="align-left" class="absolute bottom-4 right-4 w-12 h-12 text-white/5 pointer-events-none transition group-hover:text-indigo-500/10"></i>
      </div>
    </div>

    <div class="pt-6 border-t border-white/5 flex justify-end">
      <button type="submit" class="bg-indigo-600 hover:bg-indigo-500 text-white font-bold py-3 px-8 rounded-xl transition duration-300 shadow-xl shadow-indigo-500/20 flex items-center gap-2">
        <i data-lucide="save" class="w-5 h-5"></i> Simpan Project
      </button>
    </div>
  </form>
</div>
