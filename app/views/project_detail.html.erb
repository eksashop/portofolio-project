<div class="animate__animated animate__fadeIn max-w-5xl mx-auto">
  
  <div class="mb-8">
    <a href="/#projects" class="inline-flex items-center gap-2 px-4 py-2 hover:bg-white/10 rounded-xl transition text-white/70 hover:text-white font-medium">
      <i data-lucide="arrow-left" class="w-4 h-4"></i> Kembali ke Portofolio
    </a>
  </div>

  <div class="glass border border-white/10 rounded-[3rem] overflow-hidden shadow-2xl relative">
    
    <div class="absolute inset-0 bg-gradient-to-br from-indigo-500/5 via-transparent to-purple-500/5 pointer-events-none"></div>

    <!-- Image Header -->
    <div class="w-full h-80 md:h-96 relative border-b border-white/10">
      <% if @project.image_url && !@project.image_url.empty? %>
        <img src="<%= @project.image_url %>" alt="<%= @project.title %>" class="w-full h-full object-cover">
      <% else %>
        <div class="w-full h-full bg-indigo-950/40 flex items-center justify-center">
          <i data-lucide="image" class="w-24 h-24 text-indigo-500/20"></i>
        </div>
      <% end %>
      
      <div class="absolute inset-0 bg-gradient-to-t from-[#2d3748] via-[#2d3748]/50 to-transparent"></div>
      
      <!-- Content overlapping the gradient -->
      <div class="absolute bottom-0 left-0 w-full p-6 md:p-12 z-10 flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div>
          <div class="inline-flex items-center gap-2 px-3 py-1 bg-indigo-500/20 border border-indigo-500/30 rounded-full text-xs font-bold text-indigo-300 mb-4 backdrop-blur-md">
            <i data-lucide="folder" class="w-3 h-3"></i> Project Detail
          </div>
          <h1 class="text-3xl md:text-5xl font-extrabold text-white tracking-tight leading-tight">
            <%= @project.title %>
          </h1>
          <p class="text-white/50 text-sm mt-3 flex items-center gap-2">
            <i data-lucide="calendar" class="w-4 h-4"></i> 
            Dibuat pada: <%= @project.created_at.strftime("%d %B %Y") if @project.created_at %>
          </p>
        </div>
        
        <div class="flex flex-wrap gap-3">
          <% if @project.github_url && !@project.github_url.empty? %>
            <a href="<%= @project.github_url %>" target="_blank" class="flex-1 md:flex-none px-6 py-3 bg-white/10 hover:bg-white/20 border border-white/10 rounded-xl font-bold flex items-center justify-center gap-2 transition backdrop-blur-md">
              <i data-lucide="github" class="w-5 h-5"></i> Source Code
            </a>
          <% end %>
          <% if @project.demo_url && !@project.demo_url.empty? %>
            <a href="<%= @project.demo_url %>" target="_blank" class="flex-1 md:flex-none px-6 py-3 bg-indigo-600 hover:bg-indigo-500 text-white shadow-lg shadow-indigo-900/30 rounded-xl font-bold flex items-center justify-center gap-2 transition">
              <i data-lucide="external-link" class="w-5 h-5"></i> Live Demo
            </a>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Description -->
    <div class="p-8 md:p-12 relative z-10 bg-black/10">
      <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-6 border-b border-white/10 pb-4">
        <h2 class="text-xl font-bold flex items-center gap-2">
          <i data-lucide="align-left" class="w-5 h-5 text-indigo-400"></i> Deskripsi Project
        </h2>
        
        <div class="flex items-center gap-2 px-3 py-1.5 bg-white/5 border border-white/10 rounded-lg text-xs font-medium text-white/60">
          <span>Powering by</span>
          <span class="flex items-center gap-1.5 text-indigo-400 font-bold">
            <i data-lucide="layers" class="w-3.5 h-3.5"></i> Eksa Framework
          </span>
        </div>
      </div>

      <style>
        /* Hide backticks in Tailwind Typography while keeping code styling */
        .prose code::before { content: "" !important; }
        .prose code::after { content: "" !important; }
        .prose code { 
          background-color: rgba(255, 255, 255, 0.1);
          padding: 0.2em 0.4em;
          border-radius: 0.375rem;
          font-weight: 500;
          color: #a5b4fc !important;
        }
      </style>

      <div class="prose prose-invert max-w-none text-white/70 leading-relaxed markdown-body">
        <% require 'kramdown' %>
        <% require 'kramdown-parser-gfm' %>
        <%= Kramdown::Document.new(@project.description || '', input: 'GFM').to_html %>
      </div>
    </div>

  </div>
</div>

<script>
  lucide.createIcons();
</script>
