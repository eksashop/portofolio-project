<div class="animate__animated animate__fadeIn">
  <!-- Hero Section -->
  <div class="relative max-w-5xl mx-auto rounded-[3rem] p-12 overflow-hidden mb-16 text-center border border-white/10 glass shadow-2xl">
    <div class="absolute inset-0 bg-gradient-to-br from-indigo-500/20 via-purple-500/10 to-transparent"></div>
    <div class="absolute -top-40 -left-40 w-96 h-96 bg-indigo-500/30 rounded-full blur-[100px]"></div>
    <div class="absolute -bottom-40 -right-40 w-96 h-96 bg-purple-500/30 rounded-full blur-[100px]"></div>

    <div class="relative z-10 w-full max-w-3xl mx-auto">
      <div class="inline-flex items-center gap-2 px-4 py-2 bg-white/5 border border-white/10 rounded-full text-sm font-medium text-indigo-200 mb-8 backdrop-blur-md shadow-xl">
        <span class="w-2 h-2 rounded-full bg-indigo-400 animate-pulse"></span>
        Portfolio Developer
      </div>

      <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight mb-6 leading-tight">
        Portofolio Project <br><span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 to-purple-400">Ishikawa Uta</span>
      </h1>
      
      <p class="text-xl text-white/60 mb-10 max-w-2xl mx-auto leading-relaxed">
        Selamat datang di web landing page portofolio saya. Jelajahi karya dan project-project open-source terbaik yang pernah saya kembangkan.
      </p>

      <div class="flex flex-wrap justify-center gap-4">
        <a href="#projects" class="px-8 py-4 bg-indigo-600 hover:bg-indigo-500 text-white font-bold rounded-2xl transition duration-300 shadow-xl shadow-indigo-500/20 flex items-center gap-2 transform hover:-translate-y-1">
          <i data-lucide="compass" class="w-5 h-5"></i>
          Lihat Project
        </a>
      </div>
    </div>
  </div>

  <!-- Projects Grid Section -->
  <div id="projects" class="max-w-7xl mx-auto scroll-mt-10">
    <div class="flex items-center justify-between mb-12">
      <div>
        <h2 class="text-3xl font-extrabold flex items-center gap-3">
          <i data-lucide="boxes" class="text-indigo-400 w-8 h-8"></i> Project <span class="text-indigo-400">Terbaru</span>
        </h2>
        <p class="text-white/50 mt-2">Daftar project yang dikembangkan dan diunggah dari GitHub.</p>
      </div>
    </div>

    <% if @projects.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <% @projects.each do |project| %>
          <div class="group bg-white/5 border border-white/10 rounded-[2rem] overflow-hidden hover:border-indigo-500/30 transition duration-500 hover:bg-white/10 transform hover:-translate-y-2 relative shadow-2xl flex flex-col h-full">
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition duration-500 pointer-events-none z-10"></div>
            
            <div class="h-64 overflow-hidden relative border-b border-white/10">
              <% if project.image_url && !project.image_url.empty? %>
                <img src="<%= project.image_url %>" alt="<%= project.title %>" class="w-full h-full object-cover transform group-hover:scale-110 transition duration-700 ease-out">
              <% else %>
                <div class="w-full h-full bg-indigo-950/30 flex items-center justify-center">
                  <i data-lucide="image" class="w-16 h-16 text-indigo-500/20"></i>
                </div>
              <% end %>
              <div class="absolute top-4 right-4 z-20">
                <div class="bg-black/40 backdrop-blur-md border border-white/10 p-2 rounded-xl text-white/80 hover:text-white transition cursor-help" title="<%= project.created_at.strftime("%d %b %Y") if project.created_at %>">
                  <i data-lucide="calendar" class="w-4 h-4"></i>
                </div>
              </div>
            </div>

            <div class="p-8 pb-10 flex flex-col flex-grow relative z-20">
              <h3 class="text-2xl font-bold mb-3 group-hover:text-indigo-300 transition line-clamp-1"><%= project.title %></h3>
              <% 
                require 'kramdown'
                require 'kramdown-parser-gfm'
                desc_html = Kramdown::Document.new(project.description || '', input: 'GFM').to_html
                stripped_desc = desc_html.gsub(/<[^>]*>/, '').strip 
              %>
              <p class="text-white/60 text-sm leading-relaxed mb-8 flex-grow line-clamp-3"><%= stripped_desc %></p>
              
              <div class="flex flex-wrap gap-3 mt-auto">
                <a href="/project/<%= project.id.to_s %>" class="flex-1 min-w-[30%] bg-indigo-600/30 hover:bg-indigo-600 text-indigo-100 hover:text-white py-3 rounded-xl text-center font-semibold text-sm transition flex items-center justify-center gap-2 border border-indigo-500/30">
                  <i data-lucide="maximize" class="w-4 h-4"></i> Detail
                </a>
                <% if project.github_url && !project.github_url.empty? %>
                  <a href="<%= project.github_url %>" target="_blank" class="flex-1 min-w-[30%] bg-white/10 hover:bg-white/20 border border-white/10 py-3 rounded-xl text-center font-semibold text-sm transition flex items-center justify-center gap-2">
                    <i data-lucide="github" class="w-4 h-4"></i> Repo
                  </a>
                <% end %>
                <% if project.demo_url && !project.demo_url.empty? %>
                  <a href="<%= project.demo_url %>" target="_blank" class="flex-1 min-w-[30%] bg-indigo-600 hover:bg-indigo-500 py-3 rounded-xl text-center font-semibold text-sm transition flex items-center justify-center gap-2 shadow-lg shadow-indigo-900/30">
                    <i data-lucide="external-link" class="w-4 h-4"></i> Demo
                  </a>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>

      <% if @total_pages && @total_pages > 1 %>
        <div class="flex justify-center items-center gap-4 mt-16">
          <% if @page > 1 %>
            <a href="/?page=<%= @page - 1 %>#projects" class="px-5 py-2.5 bg-white/5 border border-white/10 rounded-xl hover:bg-white/10 transition flex items-center gap-2 font-semibold">
              <i data-lucide="chevron-left" class="w-4 h-4 text-indigo-400"></i> Sebelumnya
            </a>
          <% else %>
            <span class="px-5 py-2.5 bg-white/5 border border-white/10 rounded-xl flex items-center gap-2 font-semibold opacity-50 cursor-not-allowed">
              <i data-lucide="chevron-left" class="w-4 h-4 text-white/30"></i> Sebelumnya
            </span>
          <% end %>
          
          <span class="text-white/60 font-medium px-4 py-2 bg-black/20 rounded-lg border border-white/5">
            Halaman <span class="text-white"><%= @page %></span> dari <span class="text-white"><%= @total_pages %></span>
          </span>
          
          <% if @page < @total_pages %>
            <a href="/?page=<%= @page + 1 %>#projects" class="px-5 py-2.5 bg-white/5 border border-white/10 rounded-xl hover:bg-white/10 transition flex items-center gap-2 font-semibold">
              Selanjutnya <i data-lucide="chevron-right" class="w-4 h-4 text-indigo-400"></i>
            </a>
          <% else %>
            <span class="px-5 py-2.5 bg-white/5 border border-white/10 rounded-xl flex items-center gap-2 font-semibold opacity-50 cursor-not-allowed">
              Selanjutnya <i data-lucide="chevron-right" class="w-4 h-4 text-white/30"></i>
            </span>
          <% end %>
        </div>
      <% end %>
    <% else %>
      <div class="glass border border-dashed border-white/20 rounded-[3rem] p-24 text-center">
        <div class="w-24 h-24 bg-white/5 rounded-3xl mx-auto flex items-center justify-center mb-6 text-white/30 border border-white/10">
          <i data-lucide="ghost" class="w-12 h-12"></i>
        </div>
        <h3 class="text-2xl font-bold mb-2">Belum ada project</h3>
        <p class="text-white/50 max-w-sm mx-auto mb-8">Admin belum menambahkan project apa pun ke database MongoDB.</p>
        <a href="/cms/new" class="inline-flex items-center gap-2 px-6 py-3 bg-indigo-500/20 hover:bg-indigo-500/40 text-indigo-300 rounded-xl transition font-semibold border border-indigo-500/30">
          <i data-lucide="plus" class="w-4 h-4"></i> Tambah Sekarang
        </a>
      </div>
    <% end %>
  </div>
</div>

<script>
  lucide.createIcons();
</script>